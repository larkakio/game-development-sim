# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Chain (Base mainnet)
NEXT_PUBLIC_CHAIN_ID=8453

# Deployed DailyCheckIn.sol — set after `forge create` / Base deployment
# Production deployment (Base mainnet): 0x216068995d278D7637D41bF344237C1dfefA8eFE
NEXT_PUBLIC_CHECK_IN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Base.dev project (meta tag + dashboard)
NEXT_PUBLIC_BASE_APP_ID=your_base_app_id

# Builder Code from Base.dev → Settings → Builder Code (bc_…)
NEXT_PUBLIC_BUILDER_CODE=bc_your_code_here

# Optional: raw hex ERC-8021 suffix override instead of deriving from BUILDER_CODE
# NEXT_PUBLIC_BUILDER_CODE_SUFFIX=0x...

# Optional WalletConnect
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
